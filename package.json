{\n  "name": "nexus-ai",\n  "version": "1.0.0",\n  "description": "Advanced AI Chatbot Platform by W.A.I.T Tech",\n  "private": true,\n  "workspaces": [\n    "frontend",\n    "backend"\n  ],\n  "scripts": {\n    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",\n    "build": "npm run build -w frontend && npm run build -w backend",\n    "start": "npm start -w backend",\n    "lint": "npm run lint -w frontend && npm run lint -w backend",\n    "type-check": "npm run type-check -w frontend && npm run type-check -w backend"\n  },\n  "devDependencies": {\n    "concurrently": "^8.2.1"\n  }\n}\n